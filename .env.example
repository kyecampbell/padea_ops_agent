# .env.example
#
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
#
# ── Claude / Anthropic ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/padea_ops

# ── Email integration (placeholder — provider TBD) ────────────────────────────
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=agent@padea.com
EMAIL_PASSWORD=...

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Override values from config/settings.py at runtime without changing source.
# ESCALATION_THRESHOLD_USD=5000
# MAX_AGENT_ITERATIONS=20
