# .gitignore — Padea Operations Agent

# ── Environment & secrets ─────────────────────────────────────────────────────
.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Runtime logs (generated artifacts, not source) ───────────────────────────
logs/runs/*.json
logs/runs/*.jsonl
logs/html/*.html

# ── Raw & processed data (not committed — too large / sensitive) ──────────────
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Emails (fixtures kept; runtime files ignored) ─────────────────────────────
emails/outgoing/drafts/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── Claude Code project settings (machine-specific) ───────────────────────────
.claude/

# ── OS / editor noise ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Test / coverage artefacts ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
